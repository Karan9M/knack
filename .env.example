# Groq — plan generation and technique content (server)
GROQ_API_KEY=
# Optional second Groq key (separate quota). Used when the primary key hits rate limits or transient 5xx.
GROQ_API_KEY_FALLBACK=

# YouTube Data API — video search (server)
YOUTUBE_API_KEY=

# Pexels — optional fallback images for techniques (server)
PEXELS_API_KEY=

# Supabase — plan persistence (server; use service role for API routes)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
